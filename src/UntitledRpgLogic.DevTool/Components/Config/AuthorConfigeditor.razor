@using UntitledRpgLogic.Core.Configuration
@using UntitledRpgLogic.DevTool.Components.Form
@*
    File: src/UntitledRpgLogic.DevTool/Components/Config/AuthorConfigEditor.razor
    Purpose: Editor for AuthorConfig objects.
*@

@if (Value != null)
{
	<fieldset class="border p-2 mb-3">
		<legend>Author</legend>
		<StringInputField Label="Name" @bind-Value="Value.AuthorName"/>
		<StringInputField Label="Website" @bind-Value="Value.Website"/>
		<GuidInputField Label="Author ID" @bind-Value="Value.ExplicitId"/>
	</fieldset>
}

@code {

	/// <summary>
	///     The AuthorConfig object backing this editor.
	/// </summary>
	[Parameter]
	public AuthorConfig? Value { get; set; }

}
