@using UntitledRpgLogic.Core.Configuration
@using UntitledRpgLogic.DevTool.Components.Form
@*
    File: src/UntitledRpgLogic.DevTool/Components/Config/SkillDataConfigEditor.razor
    Purpose: Editor for SkillDataConfig objects.
*@

@if (Value != null)
{
	<fieldset class="border p-2 mb-3">
		<legend>Skill Data</legend>
		<StringInputField Label="Name" @bind-Value="Value.Name"/>
		<TextAreaInputField Label="Description" @bind-Value="Value.Description"/>
		@* Leveling Option Input: Todo *@
		<GuidInputField Label="Skill ID" Description="Define a unique identifier for this skill." @bind-Value="Value.Id"/>
	</fieldset>
}

@code {

	/// <summary>
	///     The <see cref="SkillDataConfig" /> instance being edited.
	/// </summary>
	[Parameter]
	public SkillDataConfig? Value { get; set; }

}
