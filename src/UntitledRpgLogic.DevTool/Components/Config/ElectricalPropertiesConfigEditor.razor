@using UntitledRpgLogic.Core.Configuration
@using UntitledRpgLogic.DevTool.Components.Form
@*
    File: src/UntitledRpgLogic.DevTool/Components/Config/ElectricalPropertiesConfigEditor.razor
    Purpose: Editor for ElectricalPropertiesConfig objects.
*@

@if (Value != null)
{
	<fieldset class="border p-2 mb-3">
		<legend>Electrical Properties</legend>
		<NumberInputField Label="Conductivity" @bind-Value="Value.Conductivity"/>
	</fieldset>
}


@code {

	/// <summary>
	///     The <see cref="ElectricalPropertiesConfig" /> instance being edited.
	/// </summary>
	[Parameter]
	public ElectricalPropertiesConfig? Value { get; set; }

}
