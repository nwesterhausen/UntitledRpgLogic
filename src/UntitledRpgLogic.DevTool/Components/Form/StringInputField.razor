@*
    A reusable component for a string input field.
    It wraps the standard InputText component with a label and form control styling.
*@
@inherits InputBase<string>

<div class="form-control">
	<fieldset class="fieldset">
		<legend class="fieldset-legend">@Label</legend>
		<InputText @bind-Value="CurrentValue" class="input input-bordered w-full"/>
		<p class="label">
			@Description
		</p>
	</fieldset>
</div>

@code {

	/// <summary>
	///     The text to display in the label for this input field.
	/// </summary>
	[Parameter]
	public string Label { get; set; } = string.Empty;

	/// <summary>
	///     Additional description for the input field.
	/// </summary>
	[Parameter]
	public string Description { get; set; } = string.Empty;

	/// <summary>
	///     This is required for the InputBase to work correctly.
	/// </summary>
	protected override bool TryParseValueFromString(string? value, out string result, out string validationErrorMessage)
	{
		result = value ?? string.Empty;
		validationErrorMessage = string.Empty;
		return true;
	}

}
